# BabyMind OS 환경변수 설정
# 이 파일을 .env로 복사한 후 값을 채워주세요.
# cp .env.example .env

# ===== Tapo 카메라 설정 (필수) =====
TAPO_USERNAME=your_tapo_email@example.com
TAPO_PASSWORD=your_tapo_password
TAPO_CAMERA_IP=192.168.0.100
TAPO_RTSP_PORT=554

# ===== AI 분석 (필수) =====
ANTHROPIC_API_KEY=sk-ant-xxx
VISION_MODEL=claude-sonnet-4-5-20250514

# ===== 아이 정보 =====
CHILD_NAME=우리아이
CHILD_AGE_MONTHS=24

# ===== 분석 설정 =====
ANALYSIS_INTERVAL=30        # 분석 주기 (초)
CAPTURE_WIDTH=1280
CAPTURE_HEIGHT=720

# ===== 이메일 알림 (Resend) =====
RESEND_API_KEY=re_xxx
PARENT_EMAIL=parent@example.com
ALERT_FROM_EMAIL=babymind@resend.dev

# ===== 카카오톡 알림 =====
KAKAO_REST_API_KEY=xxx
KAKAO_ACCESS_TOKEN=xxx

# ===== 알림 수준 =====
# all: 모든 알림 / important: 중요+위험 / danger_only: 위험만
NOTIFICATION_LEVEL=important

# ===== Supabase (선택) =====
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxx

# ===== 데이터 보관 =====
FRAME_RETENTION_MINUTES=5
ANALYSIS_RETENTION_DAYS=90
